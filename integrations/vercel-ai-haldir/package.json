  "keywords": [
    "ai-sdk",
    "vercel",
    "haldir",
    "ai-agents",
    "security",
    "governance",
    "audit",
    "compliance",
    "tools"
  ],
  "author": "Sterling <sterling@haldir.xyz>",
  "license": "MIT",
  "homepage": "https://haldir.xyz",
  "repository": {
    "type": "git",
